<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hydrogen-like MO Viewer (v3.2)</title>
    <link rel="stylesheet" href="./styles.css" />
    <script type="importmap">
      {
        "imports": {
          "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
          "three/examples/jsm/": "https://unpkg.com/three@0.160.0/examples/jsm/"
        }
      }
    </script>
  </head>
  <body>
    <header class="app-chrome">
      <nav class="menu-bar">
        <button class="menu-item" data-menu="file" data-i18n="menu_file">文件</button>
        <button class="menu-item" data-menu="window" data-i18n="menu_window">窗口</button>
        <button class="menu-item" data-menu="help" data-i18n="menu_help">帮助</button>
        <button class="menu-item" data-menu="language" data-i18n="menu_language">Language</button>
      </nav>
      <div class="tool-bar" aria-label="Main toolbar">
        <button id="toolRender" class="tool-button blue" title="显示/重画">▤</button>
        <button id="toolSave" class="tool-button green" title="导出图片">▣</button>
        <button id="toolTile" class="tool-button gray" title="平铺">▰</button>
        <button id="toolOverlap" class="tool-button stack" title="重叠">▣</button>
        <button id="toolAxis" class="tool-button" title="坐标轴" data-i18n-title="title_axis">
          <svg viewBox="0 0 24 24" width="22" height="22">
            <path d="M12 14 L12 4" stroke="#22c55e" stroke-width="2" stroke-linecap="round"/>
            <path d="M12 14 L21 19" stroke="#ef4444" stroke-width="2" stroke-linecap="round"/>
            <path d="M12 14 L5 19" stroke="#3b82f6" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
        <button id="toolXOY" class="tool-button" title="XOY 视图" data-i18n-title="title_xoy">
          <svg viewBox="0 0 24 24" width="22" height="22">
            <path d="M12 12 L12 2 M12 12 L21 17 M12 12 L3 17" stroke="#9ca3af" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M12 12 L21 17 L12 22 L3 17 Z" fill="rgba(59, 130, 246, 0.3)" stroke="#3b82f6" stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
        </button>
        <button id="toolYOZ" class="tool-button" title="YOZ 视图" data-i18n-title="title_yoz">
          <svg viewBox="0 0 24 24" width="22" height="22">
            <path d="M12 12 L12 2 M12 12 L21 17 M12 12 L3 17" stroke="#9ca3af" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M12 12 L21 17 L21 7 L12 2 Z" fill="rgba(59, 130, 246, 0.3)" stroke="#3b82f6" stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
        </button>
        <button id="toolXOZ" class="tool-button" title="XOZ 视图" data-i18n-title="title_xoz">
          <svg viewBox="0 0 24 24" width="22" height="22">
            <path d="M12 12 L12 2 M12 12 L21 17 M12 12 L3 17" stroke="#9ca3af" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M12 12 L3 17 L3 7 L12 2 Z" fill="rgba(59, 130, 246, 0.3)" stroke="#3b82f6" stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
      <div id="menuPopup" class="menu-popup" hidden></div>
    </header>
    <main class="app-shell">
      <aside class="sidebar">
        <div class="sidebar-fit">
        <div class="client-tabs">
          <button class="tab active" data-i18n="tab_orbital">氢原子轨道</button>
        </div>

        <section class="client-panel">
          <fieldset>
            <legend data-i18n="legend_wavefunction">波函数</legend>
            <div class="quantum-row">
              <label><span>n=</span><input id="nInput" type="number" min="1" max="6" value="2" /></label>
              <label><span>l=</span><input id="lInput" type="number" min="0" max="5" value="1" /></label>
              <label><span>|m|=</span><input id="mInput" type="number" min="-5" max="5" value="1" /></label>
            </div>
            <div class="check-grid three">
              <label class="check-row"><input id="cosTypeInput" type="checkbox" checked /><span data-i18n="lbl_cos_type">Cos型</span></label>
              <label class="check-row"><input id="sinTypeInput" type="checkbox" /><span data-i18n="lbl_sin_type">Sin型</span></label>
              <label class="check-row"><input id="cloudInput" type="checkbox" /><span data-i18n="lbl_electron_cloud">电子云</span></label>
            </div>
            <div class="select-action-row">
              <select id="presetInput">
                <option value="1,0,0">1s</option>
                <option value="2,0,0">2s</option>
                <option value="2,1,0">2Pz</option>
                <option value="2,1,1" selected>2Px</option>
                <option value="3,0,0">3s</option>
                <option value="3,1,0">3Pz</option>
                <option value="3,2,0">3dz2</option>
                <option value="3,2,1">3dxz</option>
                <option value="3,2,2">3dx2-y2</option>
                <option value="4,3,0">4fz3</option>
              </select>
              <button id="renderButton" class="client-link-button" data-i18n="btn_render">显示</button>
            </div>
            <label class="hidden-control">
              <span>Nuclear charge Z</span>
              <input id="zInput" type="number" min="1" max="10" value="1" />
            </label>
          </fieldset>

          <fieldset>
            <legend data-i18n="legend_display">轨道显示</legend>
            <div class="check-grid three">
              <label class="check-row"><input id="positiveLobeInput" type="checkbox" checked /><span data-i18n="lbl_positive_lobe">正瓣</span></label>
              <label class="check-row"><input id="negativeLobeInput" type="checkbox" checked /><span data-i18n="lbl_negative_lobe">负瓣</span></label>
              <label class="check-row"><input id="wireframeInput" type="checkbox" checked /><span data-i18n="lbl_wireframe">网格</span></label>
              <label class="check-row"><input id="smoothInput" type="checkbox" /><span data-i18n="lbl_smooth">光滑</span></label>
              <label class="check-row"><input id="projectionInput" type="checkbox" /><span data-i18n="lbl_projection">投影</span></label>
              <span></span>
              <label class="check-row"><input id="xySliceInput" type="checkbox" /><span data-i18n="lbl_slice_xy">xy截面</span></label>
              <label class="check-row"><input id="yzSliceInput" type="checkbox" /><span data-i18n="lbl_slice_yz">yz截面</span></label>
              <label class="check-row"><input id="xzSliceInput" type="checkbox" /><span data-i18n="lbl_slice_xz">xz截面</span></label>
              <label class="check-row"><input id="quarterInput" type="checkbox" /><span data-i18n="lbl_cut_1_4">1/4角</span></label>
              <label class="check-row"><input id="eighthInput" type="checkbox" /><span data-i18n="lbl_cut_1_8">1/8角</span></label>
              <label class="check-row"><input id="threeQuarterInput" type="checkbox" /><span data-i18n="lbl_cut_3_4">3/4角</span></label>
            </div>
            

            <div class="hidden-control">
              <label>
                <span>Display mode</span>
                <select id="modeInput">
                  <option value="marching" selected>Marching Cubes</option>
                  <option value="surface">Radial surface</option>
                  <option value="points">Point cloud</option>
                </select>
              </label>
              <label>
                <span>Slice plane</span>
                <select id="sliceInput">
                  <option value="none" selected>None</option>
                  <option value="xoy">XOY</option>
                  <option value="xoz">XOZ</option>
                  <option value="yoz">YOZ</option>
                </select>
              </label>
              <label class="check-row"><input id="nodeInput" type="checkbox" /><span>Show node surface</span></label>
              <label class="check-row"><input id="axisInput" type="checkbox" checked /><span>Show axes</span></label>
            </div>
          </fieldset>

          <fieldset>
            <legend data-i18n="legend_radial">径向</legend>
            <div class="check-grid four">
              <label class="check-row"><input id="radialRInput" type="checkbox" /><span>R</span></label>
              <label class="check-row"><input id="radialR2Input" type="checkbox" /><span>R2</span></label>
              <label class="check-row"><input id="radialRdfInput" type="checkbox" checked /><span>RDF</span></label>
              <label class="check-row muted"><input type="checkbox" disabled /><span>All</span></label>
              <label class="check-row"><input id="radialSectionInput" type="checkbox" /><span data-i18n="lbl_radial_section">横截</span></label>
              <label class="check-row"><input id="radialSideInput" type="checkbox" /><span data-i18n="lbl_radial_side">侧视</span></label>
              <label class="check-row"><input id="radialCurveInput" type="checkbox" checked /><span data-i18n="lbl_radial_curve">曲线</span></label>
              <label class="check-row"><input id="radialAxisInput" type="checkbox" /><span data-i18n="lbl_radial_axis">坐标</span></label>
            </div>
          </fieldset>

          <fieldset>
            <legend data-i18n="legend_nodes">节面</legend>
            <div class="check-grid three">
              <label class="check-row"><input id="radialNodeInput" type="checkbox" /><span data-i18n="lbl_node_radial">径向</span></label>
              <label class="check-row"><input id="polarNodeInput" type="checkbox" /><span data-i18n="lbl_node_polar">极向</span></label>
              <label class="check-row"><input id="longitudeNodeInput" type="checkbox" /><span data-i18n="lbl_node_azimuthal">经向</span></label>
            </div>
          </fieldset>

          <div class="hidden-control">
            <label>
              <span>Hidden input placeholder to preserve indices</span>
              <input id="paletteOneInput" type="checkbox" />
              <input id="paletteTwoInput" type="checkbox" checked />
            </label>
            <output id="isoValue">auto</output>
            <output id="densityValue">auto</output>
            <output id="radiusValue">auto</output>
            <output id="opacityValue">1.00</output>
            <button id="screenshotButton">Export image</button>
          </div>
        </section>

        <section class="client-panel sketch-launch-panel">
          <button id="openActivityButton" class="client-link-button sketch-launch-button" data-i18n="btn_activity">课堂互动</button>
          <button id="openAnimationButton" class="client-link-button sketch-launch-button" data-i18n="btn_animation">生成动画</button>
          <button id="openSketchButton" class="client-link-button sketch-launch-button" data-i18n="btn_sketch">画板</button>
          <button id="annotationModeButton" class="client-link-button sketch-launch-button" data-i18n="btn_annotation">讲解标注</button>
        </section>

        <section class="panel stats hidden-control">
          <dl>
            <div><dt>Name</dt><dd id="orbitalName">2p1</dd></div>
            <div><dt>Positive points</dt><dd id="posCount">0</dd></div>
            <div><dt>Negative points</dt><dd id="negCount">0</dd></div>
            <div><dt>Nodes</dt><dd id="nodeText">-</dd></div>
            <div><dt>Slice</dt><dd id="sliceText">None</dd></div>
            <div><dt>Box radius</dt><dd id="boxText">auto</dd></div>
            <div><dt>Isovalue</dt><dd id="isoText">auto</dd></div>
          </dl>
        </section>

        <!--
          Legacy controls are represented above with the same IDs so app.js can keep
          using the current calculation/rendering pipeline.
        -->
        <template>
          <label>
            <span>Display mode</span>
            <select id="modeInput">
              <option value="marching" selected>Marching Cubes</option>
              <option value="surface">Radial surface</option>
              <option value="points">Point cloud</option>
            </select>
          </label>
        </template>
        </div>
      </aside>

      <section class="workspace">
        <div class="view-grid">
          <article class="qt-window" data-window-name="projection">
            <header class="window-title">
              <span data-i18n="title_projection">轨道投影</span>
              <span class="window-controls">
                <button type="button" class="window-control-btn" data-window-action="minimize" aria-label="最小化">－</button>
                <button type="button" class="window-control-btn" data-window-action="maximize" aria-label="全屏">□</button>
                <button type="button" class="window-control-btn" data-window-action="close" aria-label="关闭">×</button>
              </span>
            </header>
            <div id="projectionViewer" class="viewer projection-viewer"></div>
            <div class="annotation-layer" data-annotation-layer="projection"></div>
          </article>

          <article class="qt-window main-window" data-window-name="orbital">
            <header class="window-title">
              <span id="viewerTitle" data-i18n="title_orbital">原子轨道</span>
              <span class="window-controls">
                <button type="button" class="window-control-btn" data-window-action="minimize" aria-label="最小化">－</button>
                <button type="button" class="window-control-btn" data-window-action="maximize" aria-label="全屏">□</button>
                <button type="button" class="window-control-btn" data-window-action="close" aria-label="关闭">×</button>
              </span>
            </header>
            <div id="viewer" class="viewer"></div>
            <div class="annotation-layer" data-annotation-layer="orbital"></div>
            <div class="status-strip">
              <span id="statusText">Ready</span>
              <button id="resetCameraButton">Reset view</button>
            </div>
          </article>

          <article class="qt-window" data-window-name="radial">
            <header class="window-title">
              <span data-i18n="title_radial">径向分布函数</span>
              <span class="window-controls">
                <button type="button" class="window-control-btn" data-window-action="minimize" aria-label="最小化">－</button>
                <button type="button" class="window-control-btn" data-window-action="maximize" aria-label="全屏">□</button>
                <button type="button" class="window-control-btn" data-window-action="close" aria-label="关闭">×</button>
              </span>
            </header>
            <div id="radialViewer" class="viewer radial-viewer"></div>
            <div class="annotation-layer" data-annotation-layer="radial"></div>
          </article>

          <article class="qt-window" data-window-name="angular">
            <header class="window-title">
              <span data-i18n="title_angular">角向函数</span>
              <span class="window-controls">
                <button type="button" class="window-control-btn" data-window-action="minimize" aria-label="最小化">－</button>
                <button type="button" class="window-control-btn" data-window-action="maximize" aria-label="全屏">□</button>
                <button type="button" class="window-control-btn" data-window-action="close" aria-label="关闭">×</button>
              </span>
            </header>
            <div id="angularViewer" class="viewer mini-viewer"></div>
            <div class="annotation-layer" data-annotation-layer="angular"></div>
          </article>

        </div>
      </section>
    </main>

    <article id="annotationToolbar" class="annotation-toolbar closed" aria-label="讲解标注工具">
      <button type="button" data-annotation-add="正相" data-i18n="btn_anno_pos">正相</button>
      <button type="button" data-annotation-add="负相" data-i18n="btn_anno_neg">负相</button>
      <button type="button" data-annotation-add="节点" data-i18n="btn_anno_node">节点</button>
      <button type="button" data-annotation-add="投影平面" data-i18n="btn_anno_plane">投影平面</button>
      <button type="button" data-annotation-add="径向节点" data-i18n="btn_anno_radial">径向节点</button>
      <button id="annotationClearButton" type="button" data-i18n="btn_anno_clear">清空标注</button>
    </article>

    <article id="sketchWindow" class="qt-window sketch-window floating-sketch closed" data-window-name="sketch">
      <header class="window-title">
        <span data-i18n="win_sketch">手绘对比</span>
        <span class="window-controls">
          <button type="button" class="window-control-btn" data-window-action="minimize" aria-label="最小化">－</button>
          <button type="button" class="window-control-btn" data-window-action="maximize" aria-label="全屏">□</button>
          <button type="button" class="window-control-btn" data-window-action="close" aria-label="关闭">×</button>
        </span>
      </header>
      <div class="sketch-panel">
        <div class="sketch-tools">
          <input id="sketchColorInput" type="color" value="#ffffff" aria-label="画笔颜色" />
          <input id="sketchSizeInput" type="range" min="2" max="28" step="1" value="5" aria-label="画笔粗细" />
          <button id="sketchPenButton" type="button" class="active" data-i18n="btn_pen">画笔</button>
          <button id="sketchEraserButton" type="button" data-i18n="btn_eraser">橡皮</button>
          <button id="sketchClearButton" type="button" data-i18n="btn_clear">清空</button>
        </div>
        <canvas id="sketchCanvas"></canvas>
      </div>
    </article>

    <article id="boxWindow" class="qt-window box-window floating-box closed" data-window-name="box">
      <header class="window-title">
        <span data-i18n="win_box">盒子设置</span>
        <span class="window-controls">
          <button type="button" class="window-control-btn" data-window-action="minimize" aria-label="最小化">－</button>
          <button type="button" class="window-control-btn" data-window-action="maximize" aria-label="全屏">□</button>
          <button type="button" class="window-control-btn" data-window-action="close" aria-label="关闭">×</button>
        </span>
      </header>
      <div class="box-panel">
        <div class="box-grid">
          <span data-i18n="lbl_box_size">尺寸</span>
          <input id="boxSizeDisplay" type="number" value="26.40" step="0.1" />
          <label class="check-row"><input id="boxInput" type="checkbox" /><span data-i18n="lbl_show_box">显示盒子</span></label>

          <span data-i18n="lbl_grid_pts">格点数</span>
          <input id="densityInput" type="number" min="20" max="200" step="2" value="90" />
          <label class="check-row"><input id="grid3dInput" type="checkbox" /><span data-i18n="lbl_3d_grid">3D网格</span></label>

          <span data-i18n="lbl_interval">间隔</span>
          <output id="intervalValue">0.367</output>
          <label class="check-row muted"><input type="checkbox" disabled /><span>lambertW</span></label>

          <span data-i18n="lbl_isovalue">等值面</span>
          <input id="isoInput" type="number" min="0.0001" max="0.08" step="0.0001" value="0.02" />
          <button id="presetButton" class="client-link-button" data-i18n="btn_presets">预设值</button>

          <span data-i18n="lbl_total_prob">总概率</span>
          <output id="probabilityValue">0.800</output>
          <button id="redrawProxyButton" class="client-link-button" data-i18n="btn_redraw">重画</button>
        </div>
        <label class="hidden-control">
          <span>Box radius</span>
          <input id="radiusInput" type="range" min="4" max="140" step="1" value="14" />
        </label>
        <label class="hidden-control">
          <span>Opacity</span>
          <input id="opacityInput" type="range" min="0.2" max="1" step="0.05" value="1" />
        </label>
        <label class="hidden-control">
          <input id="desktopMatchInput" type="checkbox" checked />
          <span>Desktop matched defaults</span>
        </label>
      </div>
    </article>

    <article id="paletteWindow" class="qt-window floating-palette closed" data-window-name="palette">
      <header class="window-title">
        <span data-i18n="win_palette">调色板</span>
        <span class="window-controls">
          <button type="button" class="window-control-btn" data-window-action="close" aria-label="关闭">×</button>
        </span>
      </header>
      <div class="box-panel" style="padding: 16px;">
        <div style="display: grid; gap: 12px;">
          <label class="color-row"><span data-i18n="lbl_positive_lobe" style="font-size: 16px;">正瓣</span><input id="positiveColorInput" type="color" value="#d83bd8" style="width: 48px; height: 32px;" /></label>
          <label class="color-row"><span data-i18n="lbl_negative_lobe" style="font-size: 16px;">负瓣</span><input id="negativeColorInput" type="color" value="#00aeb8" style="width: 48px; height: 32px;" /></label>
          <label class="color-row"><span data-i18n="lbl_bg_color" style="font-size: 16px;">背景</span><input id="backgroundColorInput" type="color" value="#000000" style="width: 48px; height: 32px;" /></label>
        </div>
      </div>
    </article>

    <article id="animationWindow"  class="qt-window animation-window floating-animation closed" data-window-name="animation">
      <header class="window-title">
        <span data-i18n="win_animation">轨道生成动画</span>
        <span class="window-controls">
          <button type="button" class="window-control-btn" data-window-action="minimize" aria-label="最小化">－</button>
          <button type="button" class="window-control-btn" data-window-action="maximize" aria-label="全屏">□</button>
          <button type="button" class="window-control-btn" data-window-action="close" aria-label="关闭">×</button>
        </span>
      </header>
      <div class="animation-panel">
        <div class="animation-head">
          <span id="animationStepBadge">第 1 步 / 6 步</span>
          <strong id="animationTitle" data-i18n="txt_anim_start">动画生成开始</strong>
        </div>
        <div style="position: relative; width: 100%; height: 100%; min-height: 400px;" id="animationContainer">
          <canvas id="animationCanvas" style="width: 100%; height: 100%; display: block;"></canvas>
          <div id="animFormulaOverlay" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 10; display: none; align-items: flex-start; justify-content: center; padding-top: 40px; box-sizing: border-box;">
            <div style="background: rgba(0,0,0,0.6); padding: 15px; border-radius: 8px; color: #fff; font-size: 24px; font-family: serif; text-align: center; border: 1px solid rgba(255,255,255,0.2);">
              <div style="margin-bottom: 10px;" id="animFormulaEq"></div>
              <div style="display: flex; gap: 40px; font-size: 16px;">
                <div id="animFormulaRadial"></div>
                <div id="animFormulaAngular"></div>
              </div>
            </div>
          </div>
          <div id="animationExportOverlay" class="animation-export-overlay" style="display: none;">
            <div class="animation-export-modal">
              <h4 data-i18n="txt_export_warn_title">导出提示</h4>
              <p data-i18n="txt_export_warn_desc">视频导出期间，请保持此页面在前台显示。<br/>请勿切换标签页或最小化浏览器，否则可能导致录制卡顿或跳帧。</p>
              <div class="animation-export-actions">
                <button id="cancelExportButton" class="client-link-button" data-i18n="btn_cancel">取消</button>
                <button id="confirmExportButton" class="client-link-button active" data-i18n="btn_confirm_export">继续导出</button>
              </div>
            </div>
          </div>
        </div>
        <p id="animationText" class="animation-text" data-i18n="txt_anim_desc">将当前的各个不同视角统一起来。</p>
        <div class="animation-progress"><span id="animationProgressFill"></span></div>
        <div class="animation-controls">
          <button id="animationRestartButton" type="button" data-i18n="btn_restart">重播</button>
          <button id="animationPrevButton" type="button" data-i18n="btn_prev">上一步</button>
          <button id="animationPlayButton" type="button" data-i18n="btn_play">播放</button>
          <button id="animationNextButton" type="button" data-i18n="btn_next">下一步</button>
          <button id="animationExportButton" type="button" data-i18n="btn_export">导出视频</button>
        </div>
      </div>
    </article>

    <article id="activityWindow" class="qt-window activity-window floating-activity closed" data-window-name="activity">
      <header class="window-title">
        <span id="activityTitle" data-i18n="win_activity">课堂互动</span>
        <span class="window-controls">
          <button type="button" class="window-control-btn" data-window-action="minimize" aria-label="最小化">－</button>
          <button type="button" class="window-control-btn" data-window-action="maximize" aria-label="全屏">□</button>
          <button type="button" class="window-control-btn" data-window-action="close" aria-label="关闭">×</button>
        </span>
      </header>
      <div class="activity-panel">
        <nav class="activity-mode-bar" aria-label="课堂互动模式">
          <button type="button" class="activity-mode-button active" data-activity-mode="predict" data-i18n="tab_predict">预测-验证</button>
          <button type="button" class="activity-mode-button" data-activity-mode="score" data-i18n="tab_score">预测评分</button>
          <button type="button" class="activity-mode-button" data-activity-mode="diagnosis" data-i18n="tab_diag">错误诊断</button>
          <button type="button" class="activity-mode-button" data-activity-mode="nodes" data-i18n="tab_nodes">节点发现</button>
          <button type="button" class="activity-mode-button" data-activity-mode="compare" data-i18n="tab_compare">轨道对比</button>
          <button type="button" class="activity-mode-button" data-activity-mode="challenge" data-i18n="tab_challenge">轨道配对</button>
          <button type="button" class="activity-mode-button" data-activity-mode="tablet" data-i18n="tab_tablet">平板课堂</button>
        </nav>

        <section id="predictPane" class="activity-pane active">
          <div class="activity-row">
            <label>
              <span data-i18n="lbl_target_orbital">目标轨道</span>
              <select id="predictTargetInput">
                <option value="2,1,1">2Px</option>
                <option value="2,1,0">2Pz</option>
                <option value="3,2,0">3dz2</option>
                <option value="3,2,1">3dxz</option>
                <option value="3,2,-1">3dyz</option>
                <option value="3,2,2">3dx2-y2</option>
                <option value="3,2,-2">3dxy</option>
              </select>
            </label>
            <button id="verifyPredictButton" type="button" data-i18n="btn_show_verify">显示验证</button>
            <button id="clearPredictButton" type="button">清空内容</button>
          </div>
          <p id="predictPrompt" class="activity-text" data-i18n="txt_predict_prompt">选择一个轨道，在左侧画出预测形状，点击显示验证与右侧真实投影对比。</p>
          <div class="predict-workspace">
            <div class="predict-draw-area">
              <div class="sketch-tools predict-tools">
                <input id="predictColorInput" type="color" value="#ffffff" aria-label="画笔颜色" />
                <input id="predictSizeInput" type="range" min="2" max="28" step="1" value="5" aria-label="画笔粗细" />
                <button id="predictPenButton" type="button" class="active" data-i18n="btn_pen">画笔</button>
                <button id="predictEraserButton" type="button" data-i18n="btn_eraser">橡皮</button>
              </div>
              <canvas id="predictCanvas"></canvas>
            </div>
            <div class="predict-result-area">
              <header class="predict-result-header">标准投影验证</header>
              <div id="predictResultImage" class="predict-result-image"></div>
            </div>
          </div>
        </section>

        <section id="scorePane" class="activity-pane" data-activity-pane="score">
          <p class="activity-text">根据您对目标轨道的预测，回答以下特征问题进行评分。</p>
          <div class="score-quiz-form" style="display: flex; flex-direction: column; gap: 12px; margin-top: 10px;">
            <label style="display: flex; justify-content: space-between; align-items: center;">
              <span>1. 该轨道的径向节点数是多少？</span>
              <input type="number" id="quizRadialInput" min="0" max="10" value="0" style="width: 60px; padding: 4px; border: 1px solid #d8dee8; border-radius: 4px;">
            </label>
            <label style="display: flex; justify-content: space-between; align-items: center;">
              <span>2. 该轨道的角向节点数是多少？</span>
              <input type="number" id="quizAngularInput" min="0" max="10" value="0" style="width: 60px; padding: 4px; border: 1px solid #d8dee8; border-radius: 4px;">
            </label>
            <div class="activity-row compact" style="margin-top: 8px;">
              <button id="scoreCurrentButton" type="button" style="width: 100%;">提交诊断并评分</button>
            </div>
          </div>
          <div id="scorePrompt" class="activity-text" style="margin-top: 16px;"></div>
        </section>

        <section id="diagnosisPane" class="activity-pane" data-activity-pane="diagnosis">
          <div class="activity-row compact">
            <button id="diagnoseNodesButton" type="button">节点诊断</button>
            <button id="diagnosePhaseButton" type="button">相位诊断</button>
            <button id="diagnoseProjectionButton" type="button">投影诊断</button>
          </div>
          <div class="activity-card-grid">
            <button type="button" class="activity-card" data-diagnosis="nodes">
              <strong>节点数检查</strong>
              <span>判断是否漏掉径向节点或角向节点。</span>
            </button>
            <button type="button" class="activity-card" data-diagnosis="phase">
              <strong>相位方向检查</strong>
              <span>提示 Px/Py/Pz、D/F 轨道方向混淆。</span>
            </button>
          </div>
          <p id="diagnosisPrompt" class="activity-text">选择诊断类型后，主视图会自动打开对应的节点、相位或投影显示。</p>
          <p class="activity-text">错误诊断不占左侧空间，只在学生提交答案或挑战答错后显示。</p>
        </section>

        <section id="nodesPane" class="activity-pane" data-activity-pane="nodes">
          <div class="activity-row compact">
            <button id="nodeRevealButton" type="button">显示节点</button>
            <button id="nodeHideButton" type="button">隐藏节点</button>
            <button type="button" data-activity-mode="predict">预测节点</button>
          </div>
          <p class="activity-text">节点发现模式适合让学生先判断节点面位置，再显示真实节点结果。</p>
        </section>

        <section id="comparePane" class="activity-pane" data-activity-pane="compare">
          <div class="activity-row compare-row">
            <label>
              <span>轨道 A</span>
              <select id="compareAInput"></select>
            </label>
            <label>
              <span>轨道 B</span>
              <select id="compareBInput"></select>
            </label>
            <button id="compareApplyButton" type="button">开始对比</button>
          </div>
          <div class="compare-view-grid">
            <div class="compare-view-card">
              <header><span id="compareATitle">轨道 A</span><button id="compareLoadAButton" type="button">载入主视图</button></header>
              <div id="compareAViewer" class="compare-viewer"></div>
              <p id="compareANotes" class="compare-notes">选择轨道后点击开始对比。</p>
            </div>
            <div class="compare-view-card">
              <header><span id="compareBTitle">轨道 B</span><button id="compareLoadBButton" type="button">载入主视图</button></header>
              <div id="compareBViewer" class="compare-viewer"></div>
              <p id="compareBNotes" class="compare-notes">选择轨道后点击开始对比。</p>
            </div>
          </div>
          <p id="compareSummary" class="activity-text">用于比较同一角向类型在不同 n 下的径向节点差异，或比较不同角向轨道的节点面和相位方向。</p>
        </section>

        <section id="challengePane" class="activity-pane">
          <div class="activity-row">
            <button id="newChallengeButton" type="button">随机出题</button>
            <label>
              <span>你的答案</span>
              <select id="challengeGuessInput">
                <option value="2,1,1">2Px</option>
                <option value="2,1,-1">2Py</option>
                <option value="2,1,0">2Pz</option>
                <option value="3,2,0">3dz2</option>
                <option value="3,2,1">3dxz</option>
                <option value="3,2,-1">3dyz</option>
                <option value="3,2,2">3dx2-y2</option>
                <option value="3,2,-2">3dxy</option>
              </select>
            </label>
            <button id="revealChallengeButton" type="button">揭晓答案</button>
          </div>
          <p id="challengePrompt" class="activity-text">点击随机出题后，观察四个窗口中的轨道并选择名称。</p>
        </section>

        <section id="tabletPane" class="activity-pane" data-activity-pane="tablet">
          <div class="activity-row compact">
            <button id="tabletLargeButton" type="button">大按钮模式</button>
            <button id="tabletRestoreButton" type="button">恢复布局</button>
            <button id="tabletScreenshotButton" type="button">快速截图</button>
          </div>
          <div class="activity-card-grid">
            <button type="button" class="activity-card" data-activity-mode="predict">
              <strong>小组预测</strong>
              <span>适合平板端学生先画、再验证。</span>
            </button>
            <button type="button" class="activity-card" data-activity-mode="challenge">
              <strong>快速抢答</strong>
              <span>适合课堂投屏随机出题。</span>
            </button>
          </div>
          <p class="activity-text">平板课堂模式后续可以放大按钮、减少参数项，只保留旋转、选择、提交和截图。</p>
        </section>
      </div>
    </article>

    <script type="module" src="./app.js?v=31"></script>
  </body>
</html>
